SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.docker

# Домен + IP Droplet (для першого деплою до DNS)
ALLOWED_HOSTS=134.209.119.77,aniloks.com.ua,www.aniloks.com.ua,127.0.0.1,localhost,web

POSTGRES_DB=nikola
POSTGRES_USER=nikola
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgres://nikola:change-me-strong-password@db:5432/nikola

CSRF_TRUSTED_ORIGINS=https://aniloks.com.ua,https://www.aniloks.com.ua

# До SSL — False. setup-ssl.sh оновить USE_HTTPS і CSRF автоматично.
USE_HTTPS=false
SITE_URL=http://134.209.119.77
SECURE_SSL_REDIRECT=False

HTTP_PORT=80

# --- Resend (SMTP) ---
# API key: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=resend
# EMAIL_HOST_PASSWORD — за замовчуванням = RESEND_API_KEY (можна не дублювати)
DEFAULT_FROM_EMAIL=noreply@aniloks.com.ua
CONTACT_EMAIL=nikolajcornejko@gmail.com

# --- Docker Compose ---
#
# Локально (runserver + SQLite через override):
#   docker compose up --build
#
# Production HTTP (DigitalOcean Droplet):
#   cp .env.example .env && nano .env
#   ./deploy/scripts/deploy.sh
#
# SSL (після DNS A-record → 134.209.119.77):
#   CERTBOT_EMAIL=admin@aniloks.com.ua ./deploy/scripts/setup-ssl.sh aniloks.com.ua www.aniloks.com.ua
#
# Оновлення на сервері:
#   git pull origin main && ./deploy/scripts/deploy.sh
#
# Контент (тексти + PDF):
#   docker compose exec web python manage.py seed_from_tz
#
# Зображення (WebP з data/seed_media/webp/):
#   docker compose exec web python manage.py seed_media --force
#
# Оновлення сертифіката (cron раз на добу):
#   0 4 * * * /var/www/nikola/deploy/scripts/renew-ssl.sh >> /var/log/nikola-ssl-renew.log 2>&1
